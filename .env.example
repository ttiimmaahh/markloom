# Copy to `.env` and adjust. Every value shown is the default.

# --- Storage ---
# Where the SQLite db + converted markdown live (mounted as a volume in compose).
DATA_DIR=/data

# --- Retention ---
# Auto-delete converted files older than this many days. 0 = keep forever.
RETENTION_DAYS=30

# --- Uploads ---
# Reject uploads larger than this (megabytes).
MAX_UPLOAD_MB=50
# Comma-separated file extensions the service will accept. Must be backed by a
# matching MarkItDown extra in backend/requirements.txt.
ALLOWED_EXTENSIONS=pdf,docx,pptx,xlsx,xls,html,htm,csv,json,xml,txt,md,epub

# --- Worker ---
# Number of concurrent conversion threads.
WORKER_THREADS=2

# --- Optional basic auth ---
# Set BOTH to require a login before use. Leave blank for open access.
# Open access is fine on a trusted LAN; DO NOT expose this service to the
# internet without setting these (or putting an authenticating proxy in front).
AUTH_USERNAME=
AUTH_PASSWORD=

# --- Optional LLM (bring your own, OpenAI-compatible) ---
# Setting LLM_MODEL + (LLM_BASE_URL or LLM_API_KEY) unlocks the "Enhanced"
# conversion option in the UI: an opt-in, per-file mode that uses the model to
# OCR text out of images embedded in PDF/DOCX/PPTX/XLSX (screenshots, diagrams,
# scans). It's much slower and may contain OCR errors; Standard stays the fast
# default. The model must be VISION-capable — a text-only server won't work and
# will hallucinate. LLM_BASE_URL points at any OpenAI-compatible API: OpenAI, or
# a local server (Ollama, LM Studio, mlx-vlm) to keep everything on your machine.
# For a local server, LLM_API_KEY can be left blank. Leave all blank to disable.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
